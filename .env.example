# ── LLM Provider (Seam 1) ──────────────────────────────────────────────────
# Swap provider by changing LLM_PROVIDER. Values: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic (swap in anytime) ────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Tool API Keys ──────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
OPENWEATHERMAP_API_KEY=...

# ── Tool Enablement (Seam 3) ───────────────────────────────────────────────
# Comma-separated. Values: echo | weather | search
ENABLED_TOOLS=echo,weather,search

# ── Policy Mode (Seam 4) ───────────────────────────────────────────────────
# Values: default | strict | permissive
POLICY_MODE=default

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://change_seams:change_seams@localhost:5432/change_seams

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
